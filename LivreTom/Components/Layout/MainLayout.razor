@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@implements IDisposable

<div class="page">
    <AuthorizeView>
        <Authorized>
            <div class="dashboard-wrapper d-flex w-100">

                @* ========== BACKDROP MOBILE ========== *@
                @if (mobileSidebarOpen)
                {
                    <div class="sidebar-backdrop" @onclick="CloseMobileSidebar"></div>
                }

                <aside class="sidebar bg-dark text-white p-4 d-flex flex-column @(sidebarCollapsed ? "sidebar-collapsed" : "") @(mobileSidebarOpen ? "sidebar-mobile-open" : "")">
                    <div class="logo mb-5 d-flex justify-content-center">
                        <img src="images/logo.png" alt="LivreTom" class="sidebar-logo" />
                    </div>

                    <nav class="flex-grow-1">
                        <ul class="list-unstyled">
                            <AuthorizeView Roles="Admin">
                                <Authorized Context="adminCtx">
                                    <li class="mb-3">
                                        <NavLink href="/" class="nav-link text-white opacity-75" Match="NavLinkMatch.All" title="Pedidos">
                                            <i class="bi bi-clipboard-check me-2"></i>
                                            <span class="sidebar-text">Pedidos</span>
                                        </NavLink>
                                    </li>
                                    <li class="mb-3">
                                        <NavLink href="admin/users" class="nav-link text-white opacity-75" title="Usuários">
                                            <i class="bi bi-people me-2"></i>
                                            <span class="sidebar-text">Usuários</span>
                                        </NavLink>
                                    </li>
                                </Authorized>
                                <NotAuthorized Context="userCtx">
                                    <li class="mb-3">
                                        <NavLink href="/" class="nav-link text-white opacity-75" Match="NavLinkMatch.All" title="Nova Música">
                                            <i class="bi bi-plus-lg me-2"></i>
                                            <span class="sidebar-text">Nova Música</span>
                                        </NavLink>
                                    </li>
                                    <li class="mb-3">
                                        <NavLink href="my-orders" class="nav-link text-white opacity-75" title="Meus Pedidos">
                                            <i class="bi bi-music-note-list me-2"></i>
                                            <span class="sidebar-text">Meus Pedidos</span>
                                        </NavLink>
                                    </li>
                                </NotAuthorized>
                            </AuthorizeView>
                        </ul>
                    </nav>

                    <AuthorizeView Roles="Admin">
                        <NotAuthorized Context="creditsUser">
                            @* Credits box expandido *@
                            <div class="credits-box mb-4 sidebar-text" @onclick="OpenTokenModal">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <i class="bi bi-coin credits-icon"></i>
                                    <small class="fw-semibold opacity-75">Tokens de Música</small>
                                </div>
                                <strong class="fs-3 d-block mb-2">@userCredits</strong>
                                <div class="btn-acquire w-100 rounded-pill fw-bold text-center">
                                    <i class="bi bi-plus-circle me-1"></i> Adquirir tokens
                                </div>
                            </div>
                            @* Credits mini (só quando colapsado no desktop) *@
                            <div class="credits-mini sidebar-collapsed-only mb-4" @onclick="OpenTokenModal" title="@userCredits Tokens">
                                <i class="bi bi-coin" style="color: #f0c040; font-size: 1.2rem;"></i>
                                <span class="fw-bold small">@userCredits</span>
                            </div>
                        </NotAuthorized>
                    </AuthorizeView>
                </aside>

                <main class="main-content flex-grow-1 bg-light min-vh-100">
                    <header class="dashboard-header bg-white p-3 shadow-sm d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-2">
                            <button class="sidebar-toggle-btn" @onclick="ToggleSidebar" title="Menu">
                                <i class="bi bi-list fs-4"></i>
                            </button>
                            <h5 class="mb-0 fw-bold d-none d-sm-block">Bem-vindo, @context.User.Identity?.Name?.Split('@')[0]!</h5>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <AuthorizeView Roles="Admin" Context="badgeAuth">
                                <span class="badge bg-danger rounded-pill px-2 py-1 small">Admin</span>
                            </AuthorizeView>

                            <div class="dropdown">
                                <div class="user-avatar rounded-circle bg-vibrant d-flex align-items-center justify-content-center text-white fw-bold"
                                     style="width: 40px; height: 40px; cursor: pointer;"
                                     data-bs-toggle="dropdown" aria-expanded="false" role="button">
                                    @context.User.Identity?.Name?.Substring(0, 2).ToUpper()
                                </div>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 py-2" style="border-radius: 16px; min-width: 240px;">
                                    <li class="px-3 py-2">
                                        <small class="text-muted d-block">Conectado como</small>
                                        <strong class="small text-truncate d-block" style="max-width: 200px;">@context.User.Identity?.Name</strong>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    <li>
                                        <a href="profile" class="dropdown-item py-2 px-3">
                                            <i class="bi bi-person me-2 opacity-75"></i> Editar Perfil
                                        </a>
                                    </li>
                                    <AuthorizeView Roles="Admin">
                                        <NotAuthorized Context="dropdownCtx">
                                            <li>
                                                <button class="dropdown-item py-2 px-3 w-100 text-start" @onclick="OpenTokenModal">
                                                    <i class="bi bi-bag-plus me-2 opacity-75"></i> Adquirir Tokens
                                                </button>
                                            </li>
                                        </NotAuthorized>
                                    </AuthorizeView>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    <li>
                                        <a href="Account/logout" class="dropdown-item py-2 px-3 text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i> Sair da Conta
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </header>
                    <div class="p-4">
                        <CascadingValue Value="(Action)OpenTokenModal" Name="OpenTokenModal">
                            @Body
                        </CascadingValue>
                    </div>
                </main>
            </div>

            @* ========== TOAST DE PAGAMENTO ========== *@
            @if (paymentStatus is not null)
            {
                <div class="payment-toast @(paymentStatus == "success" ? "toast-success" : "toast-warning")">
                    <div class="d-flex align-items-center gap-2">
                        @if (paymentStatus == "success")
                        {
                            <i class="bi bi-check-circle-fill fs-5"></i>
                            <div><strong>Pagamento confirmado!</strong> Seus tokens já foram creditados.</div>
                        }
                        else
                        {
                            <i class="bi bi-info-circle-fill fs-5"></i>
                            <div>Pagamento cancelado. Nenhuma cobrança foi realizada.</div>
                        }
                        <button type="button" class="btn-close btn-close-white ms-2" @onclick="DismissPaymentStatus"></button>
                    </div>
                </div>
            }

            @* ========== MODAL DE TOKENS ========== *@
            @if (showTokenModal)
            {
                <div class="modal-backdrop-custom" @onclick="CloseTokenModal"></div>
                <div class="token-modal-container">
                    <div class="token-modal" @onclick:stopPropagation="true">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <h4 class="fw-black mb-0">Adquirir Tokens</h4>
                                <p class="text-muted small mb-0">Escolha o pacote ideal para suas produções musicais.</p>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center"
                                    style="width: 36px; height: 36px;" @onclick="CloseTokenModal" disabled="@isPurchasing">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>

                        <div class="row g-3 mt-1">
                            @foreach (var plan in tokenPlans)
                            {
                                <div class="col-12 col-sm-6 col-lg-4">
                                    <div class="plan-card @(plan.Featured ? "plan-featured" : "") @(plan.BestDeal ? "plan-best" : "")"
                                         @onclick="() => HandlePurchase(plan)" style="@(isPurchasing ? "pointer-events: none; opacity: 0.6;" : "")">

                                        @if (plan.Badge is not null)
                                        {
                                            <span class="plan-badge @(plan.BestDeal ? "badge-best" : "badge-popular")">
                                                @plan.Badge
                                            </span>
                                        }

                                        <div class="plan-tokens">@plan.Tokens</div>
                                        <div class="plan-label">Token@(plan.Tokens > 1 ? "s" : "")</div>

                                        <div class="plan-price">R$ @plan.Price</div>
                                        <div class="plan-unit">R$ @plan.UnitPrice / token</div>

                                        @if (plan.Discount > 0)
                                        {
                                            <div class="plan-discount">
                                                <i class="bi bi-arrow-down-short"></i> @plan.Discount% mais barato
                                            </div>
                                        }

                                        <button class="btn @(plan.BestDeal ? "btn-light" : plan.Featured ? "btn-dark" : "btn-outline-dark") btn-sm rounded-pill w-100 mt-auto fw-bold"
                                                disabled="@isPurchasing">
                                            @if (isPurchasing && selectedPlan == plan.Tokens && !isCustomPurchase)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                <text>Redirecionando...</text>
                                            }
                                            else
                                            {
                                                <text>Comprar</text>
                                            }
                                        </button>
                                    </div>
                                </div>
                            }

                            @* ========== CARD PERSONALIZADO ========== *@
                            <div class="col-12 col-sm-6 col-lg-4">
                                <div class="plan-card plan-custom" style="@(isPurchasing ? "pointer-events: none; opacity: 0.6;" : "")">
                                    <div class="plan-custom-icon">
                                        <i class="bi bi-sliders2"></i>
                                    </div>
                                    <div class="plan-label">Personalizado</div>

                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <input type="number" min="1" max="500"
                                               class="form-control form-control-sm text-center rounded-3 fw-bold"
                                               style="width: 80px;"
                                               @bind="customTokenCount"
                                               @bind:event="oninput"
                                               disabled="@isPurchasing" />
                                        <span class="small text-muted">tokens</span>
                                    </div>

                                    <div class="plan-price">R$ @CustomTotalFormatted</div>
                                    <div class="plan-unit">R$ 30,00 / token · sem desconto</div>

                                    <button class="btn btn-outline-dark btn-sm rounded-pill w-100 mt-auto fw-bold"
                                            disabled="@(isPurchasing || customTokenCount < 1)"
                                            @onclick="HandleCustomPurchase">
                                        @if (isPurchasing && isCustomPurchase)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                            <text>Redirecionando...</text>
                                        }
                                        else
                                        {
                                            <text>Comprar</text>
                                        }
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-3">
                            <small class="text-muted">
                                <i class="bi bi-shield-check me-1"></i>
                                Pagamento seguro via Stripe · Cartão de crédito, débito ou PIX
                            </small>
                        </div>
                    </div>
                </div>
            }
        </Authorized>
        <NotAuthorized Context="anonCtx">
            @Body
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private int userCredits;

    // Sidebar
    private bool sidebarCollapsed;
    private bool mobileSidebarOpen;

    // Modal de Tokens
    private bool showTokenModal;
    private bool isPurchasing;
    private int selectedPlan;
    private bool isCustomPurchase;
    private int customTokenCount = 1;

    // Toast de pagamento
    private string? paymentStatus;
    private Timer? _dismissTimer;
    private bool _shouldCleanUrl;

    private static readonly System.Globalization.CultureInfo PtBr =
        System.Globalization.CultureInfo.GetCultureInfo("pt-BR");

    private string CustomTotalFormatted =>
        customTokenCount > 0
            ? (customTokenCount * 30m).ToString("N2", PtBr)
            : "0,00";

    private sealed record TokenPlan(int Tokens, string Price, string UnitPrice, int Discount, string? Badge, bool Featured, bool BestDeal);

    private static readonly TokenPlan[] tokenPlans =
    [
        new(3,   "84,90",  "28,30", 6,  null,               false, false),
        new(5,   "129,90", "25,98", 13, null,               false, false),
        new(10,  "229,90", "22,99", 23, "⭐ Popular",       true,  false),
        new(20,  "429,90", "21,50", 28, null,               false, false),
        new(30,  "599,90", "20,00", 33, "🔥 Melhor Custo",  false, true),
    ];

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(userId))
        {
            using var scope = ScopeFactory.CreateScope();
            var creditService = scope.ServiceProvider.GetRequiredService<CreditService>();
            userCredits = await creditService.GetUserCreditsAsync(userId);
        }

        // Detectar retorno do Stripe (?payment=success ou ?payment=cancelled)
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        paymentStatus = query["payment"];

        if (paymentStatus is not null)
        {
            _shouldCleanUrl = true;
            _dismissTimer = new Timer(_ => InvokeAsync(() =>
            {
                paymentStatus = null;
                StateHasChanged();
            }), null, 5000, Timeout.Infinite);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldCleanUrl)
        {
            _shouldCleanUrl = false;
            var cleanPath = new Uri(Navigation.Uri).AbsolutePath;
            Navigation.NavigateTo(cleanPath, replace: true);
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (mobileSidebarOpen)
        {
            mobileSidebarOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
        mobileSidebarOpen = !mobileSidebarOpen;
    }

    private void CloseMobileSidebar() => mobileSidebarOpen = false;

    private void DismissPaymentStatus()
    {
        paymentStatus = null;
        _dismissTimer?.Dispose();
        _dismissTimer = null;
    }

    private void OpenTokenModal()
    {
        showTokenModal = true;
        StateHasChanged();
    }

    private void CloseTokenModal() => showTokenModal = false;

    private void HandlePurchase(TokenPlan plan)
    {
        isPurchasing = true;
        selectedPlan = plan.Tokens;
        isCustomPurchase = false;

        var returnUrl = Uri.EscapeDataString(new Uri(Navigation.Uri).AbsolutePath);
        Navigation.NavigateTo($"/api/stripe/checkout?plan={plan.Tokens}&returnUrl={returnUrl}", forceLoad: true);
    }

    private void HandleCustomPurchase()
    {
        if (customTokenCount < 1) return;
        isPurchasing = true;
        isCustomPurchase = true;

        var returnUrl = Uri.EscapeDataString(new Uri(Navigation.Uri).AbsolutePath);
        Navigation.NavigateTo($"/api/stripe/checkout?plan={customTokenCount}&custom=true&returnUrl={returnUrl}", forceLoad: true);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        _dismissTimer?.Dispose();
    }
}
