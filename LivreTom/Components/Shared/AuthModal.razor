@using Microsoft.AspNetCore.Components.Forms
@using LivreTom.Models

@if (IsVisible)
{
    <div class="modal-backdrop fade show" @onclick="Close"></div>
    <div class="modal d-block fade show" tabindex="-1" @onclick="Close">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">

                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close ms-auto" @onclick="Close"></button>
                </div>

                <div class="modal-body p-5 pt-2">
                    <div class="text-center mb-4">
                        <h3 class="fw-black">@ModalText.Title</h3>
                        <p class="text-muted small">@ModalText.Subtitle</p>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert d-flex align-items-center border-0 rounded-4 mb-4 shadow-sm" style="background-color: #fff5f5; color: #e53e3e;">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            <span class="small fw-bold">@errorMessage</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(infoMessage))
                    {
                        <div class="alert d-flex align-items-center border-0 rounded-4 mb-4 shadow-sm" style="background-color: #fffbeb; color: #b45309;">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            <span class="small fw-bold">@infoMessage</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert d-flex align-items-center border-0 rounded-4 mb-4 shadow-sm" style="background-color: #f0fdf4; color: #16a34a;">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            <span class="small fw-bold">@successMessage</span>
                        </div>
                    }

                    @if (CurrentMode == AuthMode.Login)
                    {
                        <form action="Account/login" method="post">
                            <AntiforgeryToken />
                            <div class="mb-3">
                                <input name="email" type="email" class="form-control custom-input mb-3 shadow-none" placeholder="E-mail" required />
                                <input name="password" type="password" class="form-control custom-input shadow-none" placeholder="Senha" required />
                            </div>
                            <button type="submit" class="btn btn-dark w-100 rounded-pill py-3 fw-bold mb-3 shadow-sm">ENTRAR</button>
                            <a href="Account/google-login" id="google-login-btn" onclick="handleGoogleLogin(this)" class="btn btn-outline-dark w-100 rounded-pill py-3 fw-bold mb-3 d-flex align-items-center justify-content-center gap-2">
                                <span id="google-btn-content" class="d-flex align-items-center gap-2">
                                    <svg width="18" height="18" viewBox="0 0 48 48">
                                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.08 17.74 9.5 24 9.5z" />
                                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-3.59-13.46-8.66l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                                    </svg>
                                    Entrar com Google
                                </span>
                                <span id="google-btn-loading" class="d-none d-flex align-items-center gap-2">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                    Redirecionando...
                                </span>
                            </a>
                        </form>
                        <div class="text-center">
                            <button class="btn btn-link text-primary small fw-bold text-decoration-none" @onclick="() => SetMode(AuthMode.Register)">Criar conta agora</button>
                            <button class="btn btn-link text-muted small text-decoration-none" @onclick="() => SetMode(AuthMode.ForgotPassword)">Esqueci minha senha</button>
                        </div>
                    }
                    else if (CurrentMode == AuthMode.Register)
                    {
                        <form action="Account/register" method="post">
                            <AntiforgeryToken />
                            <input name="email" type="email" class="form-control custom-input mb-3" placeholder="E-mail" required />

                            <div class="mb-3 position-relative">
                                <input name="password" type="password" class="form-control custom-input"
                                       placeholder="Senha" required
                                       @oninput="OnPasswordInput" />
                            </div>

                            <div class="mb-3">
                                <input name="confirmPassword" type="password" class="form-control custom-input"
                                       placeholder="Confirme a senha" required
                                       @oninput="OnConfirmInput" />
                            </div>

                            <div class="password-requirements p-3 bg-light rounded-4 mb-3">
                                <div class="small mb-1 @(hasMinLength ? "text-success" : "text-muted")">
                                    @(hasMinLength ? "\u2705" : "\u274c") Mínimo 8 caracteres
                                </div>
                                <div class="small mb-1 @(hasUpper ? "text-success" : "text-muted")">
                                    @(hasUpper ? "\u2705" : "\u274c") Uma letra maiúscula
                                </div>
                                <div class="small mb-1 @(hasNumber ? "text-success" : "text-muted")">
                                    @(hasNumber ? "\u2705" : "\u274c") Um número
                                </div>
                                <div class="small mb-1 @(hasSpecial ? "text-success" : "text-muted")">
                                    @(hasSpecial ? "\u2705" : "\u274c") Um caractere especial (!@@#$)
                                </div>
                                <div class="small @(passwordsMatch && !string.IsNullOrEmpty(confirmPassword) ? "text-success" : "text-muted")">
                                    @(passwordsMatch && !string.IsNullOrEmpty(confirmPassword) ? "\u2705" : "\u274c") As senhas coincidem
                                </div>
                            </div>

                            <button type="submit" class="btn btn-dark w-100 rounded-pill py-3 fw-bold mb-3 shadow-sm" disabled="@(!CanSubmit)">CRIAR CONTA</button>
                        </form>
                        <button class="btn btn-link w-100 text-muted small text-decoration-none" @onclick="() => SetMode(AuthMode.Login)">Voltar para Login</button>
                    }
                    else if (CurrentMode == AuthMode.ForgotPassword)
                    {
                        <form action="Account/forgot-password" method="post" onsubmit="handleFormSubmit('forgot-btn', 'forgot-loading', 'Enviando...')">
                            <AntiforgeryToken />

                            <input name="email" type="email" class="form-control custom-input mb-3 shadow-none"
                                      placeholder="Seu e-mail cadastrado" required />

                            <button id="forgot-btn" type="submit" class="btn btn-dark w-100 rounded-pill py-3 fw-bold mb-3 shadow-sm">
                                <span id="forgot-loading" class="d-none spinner-border spinner-border-sm me-2" role="status"></span>
                                <span id="forgot-text">ENVIAR LINK</span>
                            </button>
                        </form>
                        <button class="btn btn-link w-100 text-muted small text-decoration-none"
                                @onclick="() => SetMode(AuthMode.Login)">
                            Voltar para Login
                        </button>
                    }
                    else if (CurrentMode == AuthMode.ResetPassword)
                    {
                        <form action="Account/reset-password" method="post">
                            <AntiforgeryToken />
                            <div class="mb-3">
                                <input name="password" type="password" class="form-control custom-input"
                                       placeholder="Nova senha" required
                                       @oninput="OnPasswordInput" />
                            </div>
                            <div class="mb-3">
                                <input name="confirmPassword" type="password" class="form-control custom-input"
                                       placeholder="Confirme a nova senha" required
                                       @oninput="OnConfirmInput" />
                            </div>

                            <div class="password-requirements p-3 bg-light rounded-4 mb-3">
                                <div class="small mb-1 @(hasMinLength ? "text-success" : "text-muted")">
                                    @(hasMinLength ? "\u2705" : "\u274c") Mínimo 8 caracteres
                                </div>
                                <div class="small mb-1 @(hasUpper ? "text-success" : "text-muted")">
                                    @(hasUpper ? "\u2705" : "\u274c") Uma letra maiúscula
                                </div>
                                <div class="small mb-1 @(hasNumber ? "text-success" : "text-muted")">
                                    @(hasNumber ? "\u2705" : "\u274c") Um número
                                </div>
                                <div class="small mb-1 @(hasSpecial ? "text-success" : "text-muted")">
                                    @(hasSpecial ? "\u2705" : "\u274c") Um caractere especial (!@@#$)
                                </div>
                                <div class="small @(passwordsMatch && !string.IsNullOrEmpty(confirmPassword) ? "text-success" : "text-muted")">
                                    @(passwordsMatch && !string.IsNullOrEmpty(confirmPassword) ? "\u2705" : "\u274c") As senhas coincidem
                                </div>
                            </div>

                            <button type="submit" class="btn btn-dark w-100 rounded-pill py-3 fw-bold mb-3 shadow-sm"
                                    disabled="@(!CanSubmit)">
                                REDEFINIR SENHA
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
}

<style>
    .password-requirements {
        font-size: 0.8rem;
        border: 1px solid #eee;
    }

    .text-success {
        font-weight: 600;
    }
</style>

<script>
    function handleGoogleLogin(btn) {
        document.getElementById('google-btn-content').classList.add('d-none');
        document.getElementById('google-btn-loading').classList.remove('d-none');
        btn.classList.add('disabled');
    }

    function handleFormSubmit(btnId, spinnerId, loadingText) {
        const btn = document.getElementById(btnId);
        const spinner = document.getElementById(spinnerId);
        const text = document.getElementById(btnId.replace('-btn', '-text'));

        spinner.classList.remove('d-none');
        if (text) text.textContent = loadingText;
        btn.disabled = true;
    }
</script>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    [Parameter] public string InitialError { get; set; } = "";
    [Parameter] public AuthMode InitialMode { get; set; }

    private AuthMode CurrentMode = AuthMode.Login;

    private string password = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    private string infoMessage = "";
    private string successMessage = "";

    protected override void OnParametersSet()
    {
        if (!IsVisible)
        {
            errorMessage = "";
            infoMessage = "";
            successMessage = "";

            return;
        }

        var message = InitialError ?? "";

        errorMessage = "";
        infoMessage = "";
        successMessage = "";

        if (!string.IsNullOrEmpty(message))
        {
            if (InitialMode == AuthMode.ForgotPassword)
            {
                var parts = message.Split('|');
                infoMessage = parts[0];
                if (parts.Length > 1)
                    successMessage = parts[1];
            }
            else if (message.Contains("sucesso"))
                successMessage = message;
            else
                errorMessage = message;
        }

        CurrentMode = InitialMode;
    }

    private bool hasMinLength => password.Length >= 8;
    private bool hasUpper => password.Any(char.IsUpper);
    private bool hasNumber => password.Any(char.IsDigit);
    private bool hasSpecial => password.Any(ch => !char.IsLetterOrDigit(ch));
    private bool passwordsMatch => password == confirmPassword;
    private bool IsPasswordValid => hasMinLength && hasUpper && hasNumber && hasSpecial;
    private bool CanSubmit => IsPasswordValid && passwordsMatch;

    private void OnPasswordInput(ChangeEventArgs e) => password = e.Value?.ToString() ?? "";
    private void OnConfirmInput(ChangeEventArgs e) => confirmPassword = e.Value?.ToString() ?? "";

    private (string Title, string Subtitle) ModalText => CurrentMode switch
    {
        AuthMode.Login => ("Bem-vindo de volta", "Acesse para criar suas músicas"),
        AuthMode.Register => ("Crie sua conta", "A senha deve ser forte para sua segurança"),
        AuthMode.ForgotPassword => ("Esqueci minha senha", "Digite seu e-mail para receber o link de redefinição"),
        AuthMode.ResetPassword => ("Redefinir senha", "Digite sua nova senha"),
        _ => ("", "")
    };

    private void Close()
    {
        ResetForm();
        _ = OnClose.InvokeAsync();
    }

    private void ResetForm()
    {
        password = "";
        confirmPassword = "";
        CurrentMode = AuthMode.Login;
        errorMessage = "";
        infoMessage = "";
        successMessage = "";
    }

    private void SetMode(AuthMode mode)
    {
        password = "";
        confirmPassword = "";
        errorMessage = "";
        infoMessage = "";
        successMessage = "";
        CurrentMode = mode;
    }
}
