@using LivreTom.Models
@using LivreTom.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject QuestionService QuestionService
@inject MusicService MusicService
@inject AuthenticationStateProvider AuthStateProvider

@if (IsVisible)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block fade show" tabindex="-1" @onclick="Close">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 600px;" @onclick:stopPropagation="true">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">

                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close ms-auto" @onclick="Close" disabled="@isLoading"></button>
                </div>

                <div class="modal-body px-4 px-sm-5 py-4">
                    @if (isSuccess)
                    {
                        <div class="text-center py-3">
                            <div class="mb-4">
                                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Pedido realizado com sucesso!</h5>
                            <p class="text-muted">Sua música está sendo criada. Você pode acompanhar o status em <strong>Meus Pedidos</strong>.</p>
                        </div>
                    }
                    else if (isLoading)
                    {
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Carregando...</span>
                            </div>
                            <p class="mt-3 text-muted">Carregando formulário...</p>
                        </div>
                    }
                    else if (questions == null || questions.Count == 0)
                    {
                        <div class="alert alert-warning">Nenhuma pergunta encontrada para esta categoria.</div>
                    }
                    else
                    {
                        @* Progress indicator *@
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="small fw-bold text-primary">Pergunta @(currentQuestionIndex + 1) de @questions.Count</span>
                                <span class="small text-muted">@((int)((currentQuestionIndex + 1) * 100 / questions.Count))%</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar" role="progressbar" style="width: @((currentQuestionIndex + 1) * 100 / questions.Count)%"></div>
                            </div>
                        </div>

                        @* Current question *@
                        <div class="mb-4">
                            <p class="fw-semibold mb-3">@currentQuestion.QuestionText</p>
                            @if (currentQuestion.InputType == "textarea")
                            {
                                <textarea class="form-control rounded-3" rows="4" 
                                          @bind="currentAnswer" 
                                          @bind:event="oninput"
                                          placeholder="@(currentQuestion.Placeholder ?? "Digite sua resposta aqui...")"
                                          disabled="@isSubmitting"></textarea>
                            }
                            else if (currentQuestion.InputType == "select")
                            {
                                <select class="form-control rounded-3" 
                                        @bind="currentAnswer" 
                                        disabled="@isSubmitting">
                                    <option value="">@(currentQuestion.Placeholder ?? "Selecione uma opção...")</option>
                                    @if (!string.IsNullOrEmpty(currentQuestion.OptionsJson))
                                    {
                                        @foreach (var option in currentQuestion.OptionsJson.Split(','))
                                        {
                                            <option value="@option.Trim()">@option.Trim()</option>
                                        }
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="text" class="form-control rounded-3" 
                                       @bind="currentAnswer" 
                                       @bind:event="oninput"
                                       placeholder="@(currentQuestion.Placeholder ?? "Digite sua resposta aqui...")"
                                       disabled="@isSubmitting" />
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger border-0 rounded-3 mb-3">
                                <i class="bi bi-exclamation-circle-fill me-2"></i>
                                @errorMessage
                            </div>
                        }
                    }
                </div>

                <div class="modal-footer border-0 px-4 px-sm-5 pb-4 pt-2">
                    @if (isSuccess)
                    {
                        <button type="button" class="btn btn-success rounded-pill px-4 w-100" @onclick="Close">
                            Ok
                        </button>
                    }
                    else
                    {
                        <div class="d-grid d-sm-flex gap-2 w-100">
                            <button type="button" class="btn btn-outline-secondary rounded-pill"
                                    @onclick="Close"
                                    disabled="@(isLoading || isSubmitting)">
                                Cancelar
                            </button>

                            @if (!isLoading && questions != null && questions.Count > 0)
                            {
                                @if (currentQuestionIndex > 0)
                                {
                                    <button type="button" class="btn btn-outline-primary rounded-pill"
                                            @onclick="PreviousQuestion"
                                            disabled="@isSubmitting">
                                        <i class="bi bi-arrow-left me-1"></i> Voltar
                                    </button>
                                }

                                @if (currentQuestionIndex < questions.Count - 1)
                                {
                                    <button type="button" class="btn btn-primary rounded-pill ms-sm-auto"
                                            @onclick="NextQuestion"
                                            disabled="@(string.IsNullOrWhiteSpace(currentAnswer) || isSubmitting)">
                                        Próximo
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-success rounded-pill ms-sm-auto"
                                            @onclick="SubmitForm"
                                            disabled="@(string.IsNullOrWhiteSpace(currentAnswer) || isSubmitting)">
                                        @if (isSubmitting)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        Realizar Pedido
                                    </button>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Category { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClose { get; set; }

    private List<StepQuestion> questions = new();
    private int currentQuestionIndex = 0;
    private string currentAnswer = string.Empty;
    private Dictionary<int, string> answers = new();
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool isSuccess = false;
    private string errorMessage = string.Empty;
    private string _loadedCategory = string.Empty;

    private StepQuestion currentQuestion => questions.Count > 0 ? questions[currentQuestionIndex] : null;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && _loadedCategory != Category)
        {
            await LoadQuestionsAsync();
        }
    }

    private async Task LoadQuestionsAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            questions = await QuestionService.GetQuestionsByCategoryAsync(Category);
            _loadedCategory = Category;
            currentQuestionIndex = 0;
            currentAnswer = string.Empty;
            answers.Clear();
        }
        catch (Exception ex)
        {
            errorMessage = "Erro ao carregar o formulário. Tente novamente.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NextQuestion()
    {
        if (!string.IsNullOrWhiteSpace(currentAnswer))
        {
            answers[currentQuestionIndex] = currentAnswer;
            currentAnswer = answers.ContainsKey(currentQuestionIndex + 1) ? answers[currentQuestionIndex + 1] : string.Empty;
            currentQuestionIndex++;
            errorMessage = string.Empty;
        }
    }

    private void PreviousQuestion()
    {
        if (currentQuestionIndex > 0)
        {
            answers[currentQuestionIndex] = currentAnswer;
            currentQuestionIndex--;
            currentAnswer = answers.ContainsKey(currentQuestionIndex) ? answers[currentQuestionIndex] : string.Empty;
            errorMessage = string.Empty;
        }
    }

    private async Task SubmitForm()
    {
        if (string.IsNullOrWhiteSpace(currentAnswer))
        {
            errorMessage = "Por favor, responda a última pergunta antes de enviar.";
            return;
        }

        try
        {
            isSubmitting = true;
            answers[currentQuestionIndex] = currentAnswer;

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(userId))
            {
                errorMessage = "Usuário não autenticado.";
                return;
            }

            // Montar lista de respostas ordenadas por índice da pergunta
            var userAnswers = new List<KeyValuePair<string, string>>();
            for (int i = 0; i < questions.Count; i++)
            {
                if (answers.ContainsKey(i))
                {
                    userAnswers.Add(new KeyValuePair<string, string>(questions[i].SystemKey, answers[i]));
                }
            }

            var (success, message) = await MusicService.CreateOrderAsync(userId, Category, userAnswers);

            if (success)
            {
                isSuccess = true;
            }
            else
            {
                errorMessage = message;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erro ao enviar o formulário. Tente novamente.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ResetForm()
    {
        isSuccess = false;
        currentAnswer = string.Empty;
        answers.Clear();
        currentQuestionIndex = 0;
        errorMessage = string.Empty;
    }

    private async Task Close()
    {
        ResetForm();
        await OnClose.InvokeAsync();
    }

}
