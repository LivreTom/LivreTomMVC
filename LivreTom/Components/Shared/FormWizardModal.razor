    private void NextQuestion()
    {
        if (string.IsNullOrWhiteSpace(currentAnswer) || currentQuestionIndex >= questions.Count - 1)
        {
            return;
        }

        answers[currentQuestionIndex] = currentAnswer;
        currentQuestionIndex++;
        currentAnswer = answers.TryGetValue(currentQuestionIndex, out var saved) ? saved : string.Empty;
    }

    private void PreviousQuestion()
    {
        if (currentQuestionIndex <= 0)
        {
            return;
        }

        answers[currentQuestionIndex] = currentAnswer;
        currentQuestionIndex--;
        currentAnswer = answers.TryGetValue(currentQuestionIndex, out var saved) ? saved : string.Empty;
    }

    private void ResetForm()
    {
        isSuccess = false;
        isSubmitting = false;
        isLoading = true;
        errorMessage = string.Empty;
        currentQuestionIndex = 0;
        currentAnswer = string.Empty;
        homageStepIndex = 0;
        relaxStepIndex = 0;
        creatorStepIndex = 0;
        customReferenceTracks = string.Empty;
        questions = [];
        answers.Clear();
        block4Styles.Clear();
        block8Instruments.Clear();
        homageModel = new HomageFormModel();
        relaxModel = new RelaxFormModel();
        creatorModel = new CreatorFormModel();
        showCloseConfirm = false;
    }

    private async Task Close()
    {
        ResetForm();
        loadedCategory = string.Empty;
        await OnClose.InvokeAsync();
    }

    private async Task RequestCloseAttempt()
    {
        if (isSubmitting)
        {
            return;
        }

        if (isSuccess || !HasUnsavedChanges())
        {
            await Close();
            return;
        }

        showCloseConfirm = true;
    }

    private void CloseConfirmDialog()
    {
        showCloseConfirm = false;
    }

    private async Task ConfirmDiscardAndClose()
    {
        showCloseConfirm = false;
        await Close();
    }

