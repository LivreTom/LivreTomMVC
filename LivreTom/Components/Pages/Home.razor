@page "/"
@using LivreTom.Components.Shared
@using LivreTom.Services
@using Microsoft.AspNetCore.Components.Authorization
@using LivreTom.Models
@inject QuestionService QuestionService
@inject MusicService MusicService
@inject AuthenticationStateProvider AuthStateProvider
@inject AuthenticationStateService AuthService

<PageTitle>LivreTom - Produtora e Curadoria Musical Sob Medida</PageTitle>

<AuthorizeView>
    <Authorized>
        <AuthorizeView Roles="Admin" Context="adminAuth">
            <Authorized>
                @* ========== PAINEL ADMIN ========== *@
                <div class="animate-fade-in">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-black mb-0">Pedidos</h2>
                            <p class="text-muted small mb-0">Gerencie todas as solicitações da plataforma.</p>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <button class="btn @(adminFilter is null ? "btn-dark" : "btn-outline-dark") rounded-pill px-2 px-md-3 small"
                                    @onclick="() => adminFilter = null">
                                Todos <span class="badge bg-light text-dark ms-1">@(adminOrders?.Count ?? 0)</span>
                            </button>
                            <button class="btn @(adminFilter == "Pendente" ? "btn-warning" : "btn-outline-warning") rounded-pill px-3"
                                    @onclick='() => adminFilter = "Pendente"'>
                                Pendentes <span class="badge bg-light text-dark ms-1">@(adminOrders?.Count(o => o.Status == "Pendente") ?? 0)</span>
                            </button>
                            <button class="btn @(adminFilter == "Concluído" ? "btn-success" : "btn-outline-success") rounded-pill px-3"
                                    @onclick='() => adminFilter = "Concluído"'>
                                Concluídos
                            </button>
                        </div>
                    </div>

                    @if (adminOrders is null)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2 text-muted">Carregando pedidos...</p>
                        </div>
                    }
                    else if (adminFilteredOrders.Count == 0)
                    {
                        <div class="card border-0 shadow-sm p-5 text-center" style="border-radius: 24px;">
                            <div class="mb-3 display-4">📋</div>
                            <h5 class="fw-bold">Nenhum pedido encontrado.</h5>
                        </div>
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(adminResultMessage))
                        {
                            <div class="alert @(adminResultSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show rounded-3" role="alert">
                                @adminResultMessage
                                <button type="button" class="btn-close" @onclick="() => adminResultMessage = null"></button>
                            </div>
                        }

                        <div class="d-none d-md-block table-responsive bg-white shadow-sm rounded-4 p-3">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr class="small text-uppercase text-muted">
                                        <th>#</th>
                                        <th>Usuário</th>
                                        <th>Descrição</th>
                                        <th>Data</th>
                                        <th>Status</th>
                                        <th class="text-end">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in adminFilteredOrders)
                                    {
                                        <tr>
                                            <td class="fw-bold">@order.Id</td>
                                            <td class="small">@(order.User?.Email ?? order.UserId)</td>
                                            <td class="text-truncate" style="max-width: 250px;" title="@order.FinalPrompt">
                                                @(order.Title ?? order.FinalPrompt ?? "—")
                                            </td>
                                            <td class="small">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                <span class="badge @(order.Status == "Concluído" ? "bg-success" : "bg-warning text-dark") rounded-pill px-3 py-1">
                                                    @order.Status
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                @if (order.Status == "Pendente")
                                                {
                                                    <button class="btn btn-sm btn-vibrant text-white rounded-pill px-3"
                                                            @onclick="() => OpenFulfillModal(order)">
                                                        <i class="bi bi-music-note-beamed me-1"></i> Entregar
                                                    </button>
                                                }
                                                else if (!string.IsNullOrEmpty(order.ResolvedAudioUrl))
                                                {
                                                    <button class="btn btn-sm btn-outline-success rounded-pill px-3"
                                                            @onclick="() => previewOrder = order">
                                                        <i class="bi bi-play-fill me-1"></i> Ouvir
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @* CARDS — só mobile *@

                        <div class="d-md-none d-flex flex-column gap-3">

                            @foreach (var order in adminFilteredOrders)

                            {

                                <div class="card border-0 shadow-sm p-3" style="border-radius: 16px;">

                                    <div class="d-flex justify-content-between align-items-start mb-2">

                                        <span class="fw-bold small">#@order.Id</span>

                                        <span class="badge @(order.Status == "Concluído" ? "bg-success" : "bg-warning text-dark") rounded-pill px-2">

                                            @order.Status

                                        </span>

                                    </div>

                                    <p class="small text-muted mb-1">@(order.User?.Email ?? order.UserId)</p>

                                    <p class="small mb-2">@(order.Title ?? order.FinalPrompt ?? "—")</p>

                                    <div class="d-flex justify-content-between align-items-center">

                                        <span class="small text-muted">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>

                                        @if (order.Status == "Pendente")

                                        {

                                            <button class="btn btn-sm btn-vibrant text-white rounded-pill px-3"
                                                    @onclick="() => OpenFulfillModal(order)">

                                                <i class="bi bi-music-note-beamed me-1"></i> Entregar

                                            </button>

                                        }

                                        else if (!string.IsNullOrEmpty(order.ResolvedAudioUrl))

                                        {

                                            <button class="btn btn-sm btn-outline-success rounded-pill px-3"
                                                    @onclick="() => previewOrder = order">
                                                <i class="bi bi-play-fill me-1"></i> Ouvir
                                            </button>

                                        }

                                    </div>

                                </div>

                            }

                        </div>
                    }
                </div>

                @* --- MODAL DE ENTREGA --- *@
                @if (selectedOrder is not null)
                {
                    <div class="modal-backdrop fade show"></div>
                    <div class="modal d-block fade show" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                                <div class="modal-header border-0 pb-0">
                                    <h5 class="modal-title fw-bold">Entregar Pedido #@selectedOrder.Id</h5>
                                    <button type="button" class="btn-close" @onclick="CloseFulfillModal" disabled="@isFulfilling"></button>
                                </div>
                                <div class="modal-body">
                                    <p class="text-muted small mb-3">
                                        <strong>Usuário:</strong> @(selectedOrder.User?.Email ?? selectedOrder.UserId)<br />
                                        <strong>Pedido:</strong> @selectedOrder.FinalPrompt
                                    </p>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold small">Link curto do Suno <span class="text-danger">*</span></label>
                                        <input type="url" class="form-control rounded-3" placeholder="https://suno.com/s/..."
                                               @bind="sunoUrl" disabled="@isFulfilling" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold small">Título da música</label>
                                        <input type="text" class="form-control rounded-3" placeholder="Ex: Como La Arena"
                                               @bind="fulfillTitle" disabled="@isFulfilling" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold small">Letra</label>
                                        <textarea class="form-control rounded-3" rows="4" placeholder="Cole a letra aqui..."
                                                  @bind="fulfillLyrics" disabled="@isFulfilling"></textarea>
                                    </div>
                                </div>
                                <div class="modal-footer border-0 pt-0">
                                    <button class="btn btn-outline-secondary rounded-pill px-4" @onclick="CloseFulfillModal" disabled="@isFulfilling">
                                        Cancelar
                                    </button>
                                    <button class="btn btn-vibrant text-white rounded-pill px-4"
                                            @onclick="SubmitFulfill"
                                            disabled="@(isFulfilling || string.IsNullOrWhiteSpace(sunoUrl))">
                                        @if (isFulfilling)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                        }
                                        <i class="bi bi-check-lg me-1"></i> Concluir Entrega
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                @* --- MODAL DE PREVIEW ADMIN --- *@

                @if (previewOrder is not null)

                {

                    <div class="modal-backdrop fade show"></div>

                    <div class="modal d-block fade show" tabindex="-1" @onclick="() => previewOrder = null">

                        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">

                            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">

                

                                @if (!string.IsNullOrEmpty(previewOrder.CoverImageUrl))

                                {

                                    <img src="@previewOrder.CoverImageUrl" alt="Capa" class="card-img-top" style="height: 200px; object-fit: cover;" />

                                }

                                else

                                {

                                    <div class="d-flex align-items-center justify-content-center bg-dark text-white" style="height: 200px;">

                                        <i class="bi bi-music-note-beamed display-3 opacity-50"></i>

                                    </div>

                                }

                                <div class="modal-header border-0 pb-0">

                                    <div>

                                        <h5 class="modal-title fw-bold">@(previewOrder.Title ?? "Sem título")</h5>

                                        <p class="text-muted small mb-0">@(previewOrder.User?.Email ?? previewOrder.UserId)</p>

                                    </div>

                                    <button type="button" class="btn-close ms-auto" @onclick="() => previewOrder = null"></button>

                                </div>

                                <div class="modal-body">

                                    <audio controls preload="none" class="w-100 mb-3" style="border-radius: 12px;">

                                        <source src="@previewOrder.ResolvedAudioUrl" type="audio/mpeg" />

                                    </audio>

                                    <a href="@previewOrder.ResolvedAudioUrl" download="@(previewOrder.Title ?? "musica").mp3"
                                           class="btn btn-sm btn-outline-dark rounded-pill w-100 mb-3">

                                        <i class="bi bi-download me-1"></i> Baixar MP3

                                    </a>

                                    @if (!string.IsNullOrEmpty(previewOrder.Lyrics))

                                    {

                                        <div class="p-3 bg-light rounded-3 small" style="max-height: 200px; overflow-y: auto; white-space: pre-line;">

                                            @previewOrder.Lyrics

                                        </div>

                                    }

                                </div>

                            </div>

                        </div>

                    </div>

                }
            </Authorized>

            <NotAuthorized>
                @* ========== DASHBOARD USUÁRIO ========== *@
                <div class="dashboard-home animate-fade-in">
                    <h2 class="fw-black mb-4">Qual será sua próxima produção musical?</h2>
                    <div class="row g-4">
                        @foreach (var s in ServicosList)
                        {
                            <div class="col-md-4">
                                <div class="feature-card p-4 text-center h-100 cursor-pointer border-0 shadow-sm" @onclick='() => IniciarCriacao(s.Title)'>
                                    <div class="icon-circle mx-auto mb-3">@s.Icon</div>
                                    <h5 class="fw-bold text-dark">@s.Title</h5>
                                    <p class="text-muted small mb-0">@s.Desc</p>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-5 p-5 border-dashed rounded-4 text-center text-muted">
                        <i class="bi bi-music-note-list fs-1 d-block mb-2"></i>
                        <p>As músicas que produzimos para você aparecerão aqui.</p>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </Authorized>

    <NotAuthorized>
        @* ========== LANDING PAGE ========== *@
        <div class="main-wrapper position-relative">

            <nav class="top-nav d-grid align-items-center px-4 py-4 position-absolute w-100 z-3" style="grid-template-columns: 1fr auto 1fr;">
                <div class="logo d-flex justify-content-start">
                    <img src="images/logo.png" alt="LivreTom" class="home-logo" />
                </div>
                <div class="nav-links ml-4 d-none d-md-flex gap-4">
                    <a href="#samples" class="text-dark text-decoration-none fw-medium small">Portfólio</a>
                    <a href="#manifesto" class="text-dark text-decoration-none fw-medium small">Como funciona</a>
                    <a href="#services" class="text-dark text-decoration-none fw-medium small">Serviços</a>
                </div>
                <div class="auth-buttons d-flex align-items-center gap-3 justify-content-end">
                    <a @onclick="AbrirLogin" style="cursor:pointer" class="text-dark text-decoration-none fw-medium small">Entrar</a>
                    <button class="btn btn-dark rounded-pill px-4 py-2 small fw-bold shadow-sm" @onclick="AbrirRegister">Cadastre-se</button>
                </div>
            </nav>

            <section class="section-container vh-100 d-flex flex-column justify-content-center align-items-center text-center position-relative">
                <h1 class="main-title mb-3">A Trilha Sonora<br />da Sua História.</h1>
                <p class="subtitle mx-auto mb-4 text-muted">Curadoria especializada para transformar seus sentimentos e projetos em músicas com qualidade de estúdio.</p>
                <button class="btn-glow rounded-pill px-5 py-3 shadow-lg text-white mb-5" @onclick="AbrirLogin">ENCOMENDAR MINHA MÚSICA</button>
                <a href="#samples" class="scroll-down-btn text-decoration-none text-muted position-absolute bottom-0 mb-4 d-flex flex-column align-items-center">
                    <span class="small mb-1">Ouvir portfólio</span><i class="bi bi-chevron-down fs-5"></i>
                </a>
            </section>

            <section id="samples" class="section-container vh-100 d-flex flex-column justify-content-center align-items-center bg-vibrant position-relative">
                <div class="container text-center text-white">
                    <h2 class="display-4 fw-black mb-3">"Música sob medida para o seu momento."</h2>
                    <p class="mx-auto mb-5 opacity-75" style="max-width: 600px;">Ouça o padrão de qualidade das produções que nossa equipe pode entregar para o seu projeto.</p>
                    <div class="row g-4 justify-content-center">
                        <div class="col-md-4">
                            <div class="audio-card p-4 shadow-lg text-start border-0">
                                <span class="badge bg-white text-primary mb-2">Homenagem</span>
                                <h5 class="fw-bold">Samba para o Vovô</h5>
                                <audio controls class="w-100 mt-2"><source src="#" type="audio/mpeg"></audio>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="audio-card p-4 shadow-lg text-start border-0">
                                <span class="badge bg-white text-info mb-2">Relaxamento</span>
                                <h5 class="fw-bold">Deep Meditation Loft</h5>
                                <audio controls class="w-100 mt-2"><source src="#" type="audio/mpeg"></audio>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="audio-card p-4 shadow-lg text-start border-0">
                                <span class="badge bg-white text-success mb-2">Games</span>
                                <h5 class="fw-bold">8-Bit Adventure</h5>
                                <audio controls class="w-100 mt-2"><source src="#" type="audio/mpeg"></audio>
                            </div>
                        </div>
                    </div>
                </div>
                <a href="#manifesto" class="scroll-down-btn text-decoration-none text-white position-absolute bottom-0 mb-4 d-flex flex-column align-items-center">
                    <span class="small mb-1">Como funciona?</span><i class="bi bi-chevron-down fs-5"></i>
                </a>
            </section>

            <section id="manifesto" class="section-container vh-100 d-flex flex-column justify-content-center align-items-center text-center px-4 position-relative">
                <h2 class="display-3 fw-black mb-4">Produção musical acessível.</h2>
                <p class="subtitle-large mx-auto text-secondary mb-5">Você nos conta a sua visão, e nós cuidamos de toda a direção e produção sonora.</p>
                <div class="step-circles d-flex flex-wrap justify-content-center gap-4">
                    <div class="step shadow-sm">1. Envie seu Briefing</div>
                    <div class="step shadow-sm">2. Curadoria e Direção</div>
                    <div class="step shadow-sm">3. Receba sua Produção</div>
                </div>
                <a href="#services" class="scroll-down-btn text-decoration-none text-muted position-absolute bottom-0 mb-4 d-flex flex-column align-items-center">
                    <span class="small mb-1">Ver serviços</span><i class="bi bi-chevron-down fs-5"></i>
                </a>
            </section>

            <section id="services" class="section-container min-vh-100 py-5 container d-flex flex-column justify-content-center align-items-center">
                <h2 class="section-title fw-bold mb-5 text-center mt-5">Nossos Serviços de Produção</h2>
                <div class="row g-4 justify-content-center w-100">
                    @foreach (var s in ServicosList)
                    {
                        <div class="col-md-4">
                            <div class="feature-card p-4 text-center h-100 cursor-pointer border-0" @onclick="AbrirLogin">
                                <div class="icon-circle mx-auto mb-3">@s.Icon</div>
                                <h5 class="fw-bold text-dark">@s.Title</h5>
                                <p class="text-muted small mb-0">@s.Desc</p>
                            </div>
                        </div>
                    }
                </div>

                <div class="marquee-container mt-5 pt-5 overflow-hidden w-100">
                    <div class="marquee-content d-flex gap-5 align-items-center">
                        <span>Samba Raiz</span> <span>Lo-fi Hip Hop</span> <span>Cinematic</span> <span>Trap</span> <span>Synthwave</span> <span>Bossa Nova</span>
                        <span>Samba Raiz</span> <span>Lo-fi Hip Hop</span> <span>Cinematic</span> <span>Trap</span> <span>Synthwave</span> <span>Bossa Nova</span>
                    </div>
                </div>

                <div class="final-cta text-center mt-5 pt-4">
                    <h3 class="fw-black mb-4">Pronto para dar som à sua ideia?</h3>
                    <button class="btn-glow rounded-pill px-5 py-3 shadow-lg text-white" @onclick="AbrirLogin">
                        INICIAR MEU PROJETO MUSICAL
                    </button>
                </div>
            </section>

            <footer class="py-5 border-top bg-white">
                <div class="container text-center">
                    <div class="logo d-flex mb-2 justify-content-center">
                        <img src="images/logo.png" alt="LivreTom" class="home-logo" />
                    </div>
                    <p class="text-muted small">© 2026 LivreTom - Estúdio e Curadoria Sonora.</p>
                </div>
            </footer>
        </div>
    </NotAuthorized>
</AuthorizeView>

<AuthModal IsVisible="showAuthModal" OnClose="HandleLoginClose" InitialError="@(clearMessages ? "" : AuthService.LoginError)" InitialMode="@(clearMessages? AuthMode.Login: AuthService.AuthMode)" />
<AuthModal IsVisible="showRegisterModal" OnClose="HandleRegisterClose" InitialError="@(clearMessages ? "" : AuthService.LoginError)" InitialMode="@(clearMessages ? AuthMode.Register : AuthService.AuthMode)" />
<WizardModal IsVisible="showWizard" Category="@selectedCategory" OnClose="() => showWizard = false" />

@if (showMaintenanceModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block fade show" tabindex="-1" @onclick="() => showMaintenanceModal = false">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content border-0 shadow-lg text-center p-4" style="border-radius: 24px;">
                <button type="button" class="btn-close ms-auto" @onclick="() => showMaintenanceModal = false"></button>
                <div class="modal-body py-3">
                    <div style="font-size: 4rem;">🚧</div>
                    <h4 class="fw-black mt-3 mb-2">Criação temporariamente indisponível</h4>
                    <p class="text-muted">Nossa equipe técnica já está trabalhando para solucionar o problema o mais rápido possível.</p>
                    <p class="text-muted small">Agradecemos sua compreensão! 🙏</p>
                    <button class="btn btn-dark rounded-pill px-4 mt-2" @onclick="() => showMaintenanceModal = false">
                        Fechar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // --- Shared ---
    private bool showAuthModal = false;
    private bool showRegisterModal = false;
    private bool showWizard = false;
    private string selectedCategory = "";
    private bool clearMessages = false;
    private bool showMaintenanceModal = false;

    // --- Admin ---
    private List<MusicOrder>? adminOrders;
    private string? adminFilter;
    private MusicOrder? selectedOrder;
    private string sunoUrl = "";
    private string fulfillTitle = "";
    private string fulfillLyrics = "";
    private bool isFulfilling;
    private string? adminResultMessage;
    private bool adminResultSuccess;
    private MusicOrder? previewOrder;

    private List<MusicOrder> adminFilteredOrders =>
        adminOrders?.Where(o => adminFilter is null || o.Status == adminFilter).ToList() ?? [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var isAuthenticated = user.Identity?.IsAuthenticated == true;

        if (isAuthenticated && user.IsInRole("Admin"))
        {
            adminOrders = await MusicService.GetAllOrdersAsync();
        }
        else if (!isAuthenticated && (AuthService.HasError || AuthService.AuthMode == AuthMode.ResetPassword))
        {
            showAuthModal = true;
        }
    }

    // --- Admin methods ---
    private void OpenFulfillModal(MusicOrder order)
    {
        selectedOrder = order;
        sunoUrl = "";
        fulfillTitle = "";
        fulfillLyrics = "";
        adminResultMessage = null;
    }

    private void CloseFulfillModal() => selectedOrder = null;

    private async Task SubmitFulfill()
    {
        if (selectedOrder is null || string.IsNullOrWhiteSpace(sunoUrl)) return;

        isFulfilling = true;
        var (success, message) = await MusicService.FulfillOrderAsync(
            selectedOrder.Id,
            sunoUrl.Trim(),
            string.IsNullOrWhiteSpace(fulfillTitle) ? null : fulfillTitle.Trim(),
            string.IsNullOrWhiteSpace(fulfillLyrics) ? null : fulfillLyrics.Trim()
        );

        adminResultSuccess = success;
        adminResultMessage = message;
        isFulfilling = false;

        if (success)
        {
            selectedOrder = null;
            adminOrders = await MusicService.GetAllOrdersAsync();
        }
    }

    // --- User methods ---
    private void AbrirLogin() { AuthService.ClearErrors(); clearMessages = true; showAuthModal = true; }
    private void AbrirRegister() { AuthService.ClearErrors(); clearMessages = true; showRegisterModal = true; }
    private void HandleLoginClose() { showAuthModal = false; clearMessages = false; AuthService.ClearErrors(); }
    private void HandleRegisterClose() { showRegisterModal = false; clearMessages = false; AuthService.ClearErrors(); }

    private static readonly Dictionary<string, string> CategoryMap = new() { { "Homenagens", "Homenagem" } };

    private void IniciarCriacao(string categoria)
    {
        showMaintenanceModal = true;
    }

    private static readonly List<ServiceItem> ServicosList =
    [
        new("🎁", "Homenagens", "Composições exclusivas para tornar datas inesquecíveis."),
        new("🧘", "Relaxamento", "Produção de sons ambientes para foco e meditação."),
        new("📹", "Criadores", "Trilhas originais curadas para seus vídeos."),
        new("🪄", "Masterização", "Tratamento profissional para melhorar seus áudios."),
        new("↔️", "Versões Estendidas", "Expandimos trechos curtos em músicas completas."),
        new("🎸", "Custom Solos", "Produção de arranjos instrumentais sob medida.")
    ];
}
